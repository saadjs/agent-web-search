{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "agent-web-search",
  "compatibility_date": "2026-05-16",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "agent-web-search.saad.sh",
      "custom_domain": true
    }
  ]
}
